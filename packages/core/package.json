{
  "name": "moriui",
  "type": "module",
  "version": "0.1.0",
  "description": "基于 Reka UI 与 Nova 视觉语言的 Vue 组件库。",
  "license": "MIT",
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json",
      "./style.css": "./dist/style.css"
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "vp run build"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@lucide/vue": "catalog:",
    "@tanstack/vue-table": "catalog:",
    "@unovis/ts": "catalog:",
    "@unovis/vue": "catalog:",
    "embla-carousel": "catalog:",
    "embla-carousel-autoplay": "catalog:",
    "embla-carousel-vue": "catalog:",
    "reka-ui": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "vue-sonner": "catalog:"
  },
  "devDependencies": {
    "@internationalized/date": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "bumpp": "catalog:",
    "playwright": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "unplugin-vue": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-vue": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
